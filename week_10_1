<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elite Web Dev Bootcamp</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }

    body { line-height: 1.6; background: #0f172a; color: #e5e7eb; }

    header {
      background: radial-gradient(circle at top, #6366f1, #0f172a);
      padding: 100px 20px;
      text-align: center;
    }

    header h1 { font-size: 3rem; margin-bottom: 15px; }
    header p { font-size: 1.2rem; margin-bottom: 20px; }

    .badge {
      background: #22c55e;
      display: inline-block;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
      margin-bottom: 15px;
    }

    .btn {
      background: linear-gradient(135deg, #facc15, #f97316);
      color: black;
      padding: 14px 28px;
      border: none;
      border-radius: 30px;
      cursor: pointer;
      font-weight: 600;
      transition: 0.3s;
    }

    .btn:hover { transform: scale(1.05); }

    section { padding: 70px 20px; text-align: center; }

    .features, .courses, .pricing {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 25px;
      margin-top: 40px;
    }

    .card {
      background: rgba(255,255,255,0.05);
      padding: 25px;
      border-radius: 20px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.1);
      transition: 0.3s;
    }

    .card:hover { transform: translateY(-10px); }

    .card h3 { margin-bottom: 10px; }

    .testimonial {
      max-width: 700px;
      margin: auto;
      font-style: italic;
      opacity: 0.9;
    }

    .logos {
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
      margin-top: 20px;
      opacity: 0.7;
    }

    .price-card {
      border: 2px solid #6366f1;
    }

    .form {
      max-width: 400px;
      margin: 30px auto;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    input {
      padding: 12px;
      border-radius: 8px;
      border: none;
    }

    footer {
      background: #020617;
      padding: 20px;
      text-align: center;
    }

    @media (max-width: 768px) {
      header h1 { font-size: 2.2rem; }
    }
  </style>
</head>
<body>

<header>
  <div class="badge">🚀 Next Batch Starts Soon</div>
  <h1>Become a Job-Ready Full Stack Developer</h1>
  <p>0 to placement in 12 weeks. Build real projects, crack interviews.</p>
  <button class="btn" onclick="scrollToForm()">Apply Now</button>
</header>

<section>
  <h2>Trusted by Students Placed At</h2>
  <div class="logos">
    <span>Google</span>
    <span>Amazon</span>
    <span>Infosys</span>
    <span>TCS</span>
  </div>
</section>

<section>
  <h2>Why This Bootcamp?</h2>
  <div class="features">
    <div class="card">
      <h3>Industry Mentors</h3>
      <p>Learn directly from working developers.</p>
    </div>
    <div class="card">
      <h3>Real Projects</h3>
      <p>Build apps that actually go in your portfolio.</p>
    </div>
    <div class="card">
      <h3>Placement Support</h3>
      <p>Resume, mock interviews & referrals.</p>
    </div>
  </div>
</section>

<section>
  <h2>Curriculum</h2>
  <div class="courses">
    <div class="card">
      <h3>Frontend</h3>
      <p>HTML, CSS, JavaScript, React</p>
    </div>
    <div class="card">
      <h3>Backend</h3>
      <p>Node.js, Express, MongoDB</p>
    </div>
    <div class="card">
      <h3>Advanced</h3>
      <p>APIs, Auth, Deployment</p>
    </div>
  </div>
</section>

<section>
  <h2>Pricing</h2>
  <div class="pricing">
    <div class="card price-card">
      <h3>₹4999</h3>
      <p>Full Bootcamp Access</p>
      <p>Duration: 12 Weeks</p>
      <button class="btn">Enroll Now</button>
    </div>
  </div>
</section>

<section>
  <h2>What Students Say</h2>
  <div class="testimonial">
    "Got placed within 3 months. This changed my career."
  </div>
</section>

<section>
  <h2>Apply Now</h2>
  <form class="form">
    <input type="text" placeholder="Your Name" required>
    <input type="email" placeholder="Email Address" required>
    <button class="btn">Submit Application</button>
  </form>
</section>

<footer>
  <p>© 2026 Elite Bootcamp. All rights reserved.</p>
</footer>

<script>
  function scrollToForm() {
    document.querySelector('.form').scrollIntoView({ behavior: 'smooth' });
  }
</script>
</body>
</html>
